        <!-- Notas -->
        <mxCell id="notes" value="Notas:&#xa;- API Key validada com constant-time comparison (previne timing attacks)&#xa;- CPF validado com algoritmo completo (2 digitos verificadores)&#xa;- JWT expira em 3600 segundos (1 hora) por padrao&#xa;- Conexao MySQL com SSL obrigatorio em producao" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
